{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>konflux-ci/mintmaker//config/renovate/renovate.json"
  ],
  "enabledManagers": [
    "tekton",
    "dockerfile",
    "rpm-lockfile"
  ],
  "tekton": {
    "schedule": ["0 0 * * *"]
  },
  "dockerfile": {
    "schedule": ["0 0 * * *"]
  },
  "addLabels": [
    "approved",
    "lgtm",
    "konflux",
    "mintmaker"
  ],
  "ignorePaths": ["upstream/**"],
  "autoApprove": true,
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "automerge": true
    }
  ]
}
